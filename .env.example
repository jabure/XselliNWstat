# Kopiere diese Datei zu ".env" und trage einen eigenen, langen, zufälligen Wert ein.
# Zum Erzeugen z.B.: openssl rand -hex 32
JWT_SECRET=hier-einen-langen-zufaelligen-string-eintragen

# Nur dieser Benutzername darf die Presets & Formeln bearbeiten (registrier
# dich im Frontend einmal mit genau diesem Namen als dein Admin-Konto).
ADMIN_USERNAME=Xselli
